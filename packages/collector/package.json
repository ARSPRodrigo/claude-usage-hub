{
  "name": "@claude-usage-hub/collector",
  "version": "0.2.0",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./config": {
      "types": "./dist/config.d.ts",
      "import": "./dist/config.js"
    }
  },
  "bin": {
    "claude-hub-collector": "dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "build:bundle": "node bundle.cjs",
    "dev": "tsx src/cli.ts",
    "clean": "rm -rf dist",
    "test": "vitest run",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@claude-usage-hub/shared": "workspace:*",
    "commander": "^12.1.0",
    "tinyglobby": "^0.2.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "esbuild": "^0.25.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0"
  }
}
