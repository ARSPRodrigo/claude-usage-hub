# ─── Required ────────────────────────────────────────────────────────────────

# Deployment mode: "team" enables auth, "local" is single-user with no auth
MODE=team

# Server port (default: 8080)
PORT=8080

# Secret key for signing JWTs — generate with: openssl rand -hex 32
JWT_SECRET=change-me-to-a-random-string

# Admin account bootstrapped on first start (team mode only)
ADMIN_EMAIL=admin@yourcompany.com
ADMIN_PASSWORD=change-me

# Google OAuth client ID (Web application type from Google Cloud Console)
# Create at: https://console.cloud.google.com → APIs & Services → Credentials
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com

# Restrict Google login to this Google Workspace domain
ALLOWED_DOMAIN=yourcompany.com

# ─── Optional ────────────────────────────────────────────────────────────────

# SQLite database path (default: /data/usage.db inside Docker)
DB_PATH=/data/usage.db

# How many days of data to retain (default: 90)
RETENTION_DAYS=90
