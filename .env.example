# Server
PORT=3000
NODE_ENV=production

# Authentication
JWT_SECRET=change-me-to-a-random-string

# Admin account (created on first run)
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-me

# Database
DB_PATH=/data/claude-usage-hub.db

# Data retention (days)
RETENTION_DAYS=90

# SMTP (for alerts)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=claude-usage-hub@example.com

# Pricing
PRICING_MODE=auto
# auto: fetch from LiteLLM, fallback to hardcoded
# manual: use hardcoded pricing only
